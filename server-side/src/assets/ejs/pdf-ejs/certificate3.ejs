<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Certificate of Participation</title>

    <style>
        /* A4 Landscape Dimensions */
        @page {
            size: A4 landscape;
            margin: 0;
        }

        @font-face {
            font-family: 'Alex Brush';
            src: url('<%= fonts.alexbrush %>') format('truetype');
        }

        @font-face {
            font-family: 'Cinzel';
            src: url('<%= fonts.cinzel %>') format('truetype');
        }

        @font-face {
            font-family: 'Montserrat';
            src: url('<%= fonts.montserrat %>') format('truetype');
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: #f0f0f0;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .certificate-wrapper {
            width: 297mm;
            height: 210mm;
            background-color: #ffffff;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        /* --- Decorative Corner Elements --- */
        .corner-decor {
            position: absolute;
            z-index: 1;
        }

        /* Top-left diagonal blue triangle */
        .decor-top-left {
            top: 0;
            left: 0;
            width: 200px;
            height: 200px;
            background: linear-gradient(135deg, #002b7f 0%, #0056b3 100%);
            clip-path: polygon(0 0, 100% 0, 0 100%);
        }

        /* Top-left gold triangle accent */
        .decor-top-left-gold {
            top: 15px;
            left: 50px;
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #d4af37 0%, #f0e68c 100%);
            clip-path: polygon(0 0, 100% 0, 0 100%);
        }

        /* Top-right small gold triangle */
        .decor-top-right {
            top: 0;
            right: 20px;
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, #d4af37 0%, #f0e68c 100%);
            clip-path: polygon(100% 0, 100% 100%, 0 0);
        }

        /* Bottom-right diagonal blue triangle */
        .decor-bottom-right {
            bottom: 0;
            right: 0;
            width: 220px;
            height: 220px;
            background: linear-gradient(315deg, #002b7f 0%, #0056b3 100%);
            clip-path: polygon(100% 100%, 100% 0, 0 100%);
        }

        /* Bottom-right gold triangle accent */
        .decor-bottom-right-gold {
            bottom: 30px;
            right: 40px;
            width: 100px;
            height: 100px;
            background: linear-gradient(315deg, #d4af37 0%, #f0e68c 100%);
            clip-path: polygon(100% 100%, 100% 0, 0 100%);
        }

        /* Bottom-left small gold triangle */
        .decor-bottom-left {
            bottom: 0;
            left: 20px;
            width: 60px;
            height: 60px;
            background: linear-gradient(225deg, #d4af37 0%, #f0e68c 100%);
            clip-path: polygon(0 100%, 100% 100%, 0 0);
        }

        /* Border box */
        .border-frame {
            position: absolute;
            top: 30px;
            left: 40px;
            right: 40px;
            bottom: 30px;
            border: 2px solid #b8b8b8;
            z-index: 2;
            border-radius: 4px;
        }

        /* --- Content Layout --- */
        .content {
            position: relative;
            z-index: 10;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 30mm 50mm;
            text-align: center;
        }

        /* Logos Header */
        .logos {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 20px;
            gap: 15px;
        }

        .logos img {
            height: 70px;
            width: auto;
            object-fit: contain;
        }

        /* Medal/Badge SVG */
        .medal-badge {
            position: absolute;
            top: 50px;
            right: 80px;
            width: 100px;
            height: 100px;
            z-index: 11;
        }

        /* Main Heading */
        .main-title {
            font-family: 'Cinzel', serif;
            font-size: 60pt;
            color: #002b7f;
            margin: 0;
            letter-spacing: 6px;
            line-height: 1;
            font-weight: 700;
        }

        .sub-title {
            font-size: 14pt;
            letter-spacing: 4px;
            color: #666;
            font-weight: 600;
            margin-top: 8px;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        /* Certification Line */
        .certify-line {
            font-size: 11pt;
            color: #333;
            margin-bottom: 20px;
            font-weight: 400;
            letter-spacing: 1px;
        }

        /* Recipient Name */
        .recipient-name {
            font-family: 'Alex Brush', cursive;
            font-size: 48pt;
            color: #d4af37;
            margin: 10px 0;
            min-width: 60%;
            padding: 0;
        }

        /* Name underline */
        .name-underline {
            width: 70%;
            height: 1px;
            background-color: #333;
            margin: 10px auto 25px;
        }

        /* Description */
        .description {
            font-size: 12pt;
            color: #444;
            max-width: 90%;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .bold {
            font-weight: 700;
            color: #002b7f;
        }

        /* --- Signees --- */
        .signees {
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-top: auto;
            padding-top: 20px;
            border-top: 1px solid #ccc;
        }

        .signee-box {
            width: 28%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .signee-signature img {
            height: 60px;
            object-fit: contain;
            margin-bottom: 12px;
            display: block;
        }

        .signee-line {
            width: 100%;
            border-top: 1.5px solid #333;
            margin-bottom: 6px;
            padding-top: 8px;
            font-weight: 600;
            font-size: 10pt;
            color: #000;
            min-height: 15px;
        }

        .signee-role {
            font-size: 9pt;
            font-style: italic;
            text-transform: uppercase;
            color: #666;
            letter-spacing: 1px;
            margin-top: 4px;
        }

        /* Date and Location */
        .date-location {
            font-size: 10pt;
            color: #666;
            margin-top: 8px;
        }
    </style>
</head>

<body>
    <div class="certificate-wrapper">
        <!-- Decorative Corner Elements -->
        <div class="corner-decor decor-top-left"></div>
        <div class="corner-decor decor-top-left-gold"></div>
        <div class="corner-decor decor-top-right"></div>
        <div class="corner-decor decor-bottom-right"></div>
        <div class="corner-decor decor-bottom-right-gold"></div>
        <div class="corner-decor decor-bottom-left"></div>

        <!-- Border Frame -->
        <div class="border-frame"></div>

        <!-- Medal/Badge SVG -->
        <svg class="medal-badge" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer gold circle -->
            <circle cx="50" cy="50" r="45" fill="#d4af37" stroke="#b8860b" stroke-width="2"/>
            <!-- Inner lighter circle -->
            <circle cx="50" cy="50" r="40" fill="#f0e68c" stroke="#d4af37" stroke-width="1"/>
            <!-- Star pattern -->
            <g fill="#b8860b">
                <circle cx="50" cy="20" r="3" />
                <circle cx="73" cy="27" r="3" />
                <circle cx="80" cy="50" r="3" />
                <circle cx="73" cy="73" r="3" />
                <circle cx="50" cy="80" r="3" />
                <circle cx="27" cy="73" r="3" />
                <circle cx="20" cy="50" r="3" />
                <circle cx="27" cy="27" r="3" />
            </g>
            <!-- Center star -->
            <polygon points="50,35 56,48 70,48 60,56 65,70 50,62 35,70 40,56 30,48 44,48" fill="#b8860b"/>
        </svg>

        <div class="content">
            <!-- Logos Header -->
            <% if (images && images.main_logo) { %>
            <div class="logos">
                <img src="<%= images.main_logo %>" alt="Logos">
            </div>
            <% } %>

            <!-- Header Titles -->
            <h1 class="main-title">CERTIFICATE</h1>
            <div class="sub-title">OF PARTICIPATION</div>

            <!-- Certification Text -->
            <div class="certify-line">This Certificate is Proudly Presented to:</div>

            <!-- Name of Participant -->
            <div class="recipient-name"><%= student_name %></div>
            <div class="name-underline"></div>

            <!-- Event Description -->
            <div class="description">
                For being a participant of <span class="bold"><%= event_name %></span>
                <% if (typeof event_theme !== 'undefined' && event_theme) { %>
                with the theme <span class="bold">"<%= event_theme %>"</span>
                <% } %>
                held on <span class="bold"><%= event_date %></span>, from <span
                    class="bold"><%= event_start_time %></span> to <span class="bold"><%= event_end_time %></span>
                at <span class="bold"><%= event_venue_specific %></span><% if (event_venue) { %>,
                <%= event_venue %><% } %>.
            </div>

            <!-- Signees Section -->
            <div class="signees">
                <% for (let i = 0; i < signees.length; i++) { %>
                    <div class="signee-box">
                        <% if (signees[i].e_sig && images && images[signees[i].e_sig]) { %>
                        <div class="signee-signature">
                            <img src="<%= images[signees[i].e_sig] %>" alt="signature" />
                        </div>
                        <% } %>
                        <div class="signee-line"><%= signees[i].name %></div>
                        <div class="signee-role"><%= signees[i].designation %></div>
                    </div>
                    <% } %>
            </div>

            <!-- Date and Location -->
            <div class="date-location">
                <span style="margin-right: 40px;"><strong>Location:</strong> <%= event_venue_specific %></span>
                <span><strong>Date:</strong> <%= event_date %></span>
            </div>
        </div>
    </div>
</body>

</html>
