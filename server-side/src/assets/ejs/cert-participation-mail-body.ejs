<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Certificate Of Participation</title>
</head>

<body
    style="margin: 0; padding: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f4f7f9; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%"
        style="table-layout: fixed; background-color: #f4f7f9;">
        <tr>
            <td align="center" style="padding: 40px 0;">
                <table border="0" cellpadding="0" cellspacing="0" width="600"
                    style="background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #e1ebee;">
                    <!-- Header with Branding -->
                    <tr>
                        <td align="center"
                            style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); padding: 50px 20px;">
                            <h1
                                style="color: #ffffff; margin: 0; font-size: 28px; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; font-family: 'Montserrat', sans-serif;">
                                PSITS UC-Main</h1>
                            <p
                                style="color: rgba(255,255,255,0.8); margin: 10px 0 0 0; font-size: 14px; text-transform: uppercase; letter-spacing: 1.5px;">
                                Recognition of Achievement</p>
                        </td>
                    </tr>

                    <!-- Content Area -->
                    <tr>
                        <td style="padding: 40px 50px; color: #334155; line-height: 1.7;">
                            <h2 style="color: #0f172a; margin: 0 0 20px 0; font-size: 24px; font-weight: 600;">Dear
                                <%= student_name %>,</h2>

                            <p style="margin: 0 0 16px 0; font-size: 16px;">We are delighted to celebrate your
                                successful completion and Participation in the <strong
                                    style="color: #2563eb;">"<%= event_name %>"</strong>.</p>

                            <p style="margin: 0 0 24px 0; font-size: 16px;">Your dedication and contribution to the
                                event are highly appreciated. Attached to this email, you will find your official
                                <strong>Certificate of Participation</strong> in PDF format.
                            </p>

                            <!-- Call to Action / Info Box -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%"
                                style="background-color: #f8fafc; border-left: 4px solid #3b82f6; border-radius: 4px; margin: 30px 0;">
                                <tr>
                                    <td style="padding: 20px;">
                                        <p style="margin: 0; font-size: 15px; color: #475569; line-height: 1.5;">
                                            <strong style="color: #1e3a8a;">Important:</strong> Please download the
                                            attached PDF to view your professional certificate. You can print this
                                            document or share it digitally as part of your achievement portfolio.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0 0 16px 0; font-size: 16px;">Congratulations on this accomplishment! We
                                look forward to seeing you at our next activities.</p>

                            <p style="margin: 40px 0 0 0; font-size: 16px;">Warm regards,<br><strong
                                    style="color: #0f172a;">The PSITS Team</strong></p>
                        </td>
                    </tr>

                    <!-- Footer with Logos -->
                    <tr>
                        <td
                            style="background-color: #f1f5f9; padding: 40px 30px; text-align: center; border-top: 1px solid #e2e8f0;">
                            <p
                                style="color: #64748b; font-size: 12px; margin: 0; line-height: 1.5; text-transform: uppercase; letter-spacing: 1px;">
                                &copy; <%= new Date().getFullYear() %> PSITS - University of Cebu Main Campus<br>
                                <span style="font-size: 11px;">College of Computer Studies Department</span>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>

</html>